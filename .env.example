# ─── LLM Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model (claude-sonnet-4-6 | claude-haiku-4-5 | gpt-4o)
DEFAULT_MODEL=claude-sonnet-4-6

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://agentgw:agentgw@localhost:5432/agentgateway
SYNC_DATABASE_URL=postgresql://agentgw:agentgw@localhost:5432/agentgateway

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
PROMPT_CACHE_TTL=3600

# ─── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
API_KEY_PREFIX=agw_

# ─── GitHub Integration ───────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Notion Integration ───────────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Gmail Integration (OAuth2) ───────────────────────────────────────────────
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Linear Integration ───────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
AUDIT_LOG_RETENTION_DAYS=90

# ─── Rate Limiting ────────────────────────────────────────────────────────────
DEFAULT_RATE_LIMIT_RPM=60
DEFAULT_RATE_LIMIT_TOKENS_PER_DAY=1000000
